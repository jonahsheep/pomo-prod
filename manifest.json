{
  "manifest_version": 3,
  "name": "Focus Break",
  "version": "1.0.0",
  "description": "Pomodoro timer that forces you to take real breaks",
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "tabs"
  ],
  "background": {
    "service_worker": "scripts/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Focus Break",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options/options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
